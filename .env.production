# Set VITE_API_URL to your Azure App Service URL before building for production.
# e.g. https://nextgoalwins-api.azurewebsites.net
# In GitHub Actions this is injected as a secret; in Azure Static Web Apps it
# is set as an Application Setting named VITE_API_URL.
VITE_API_URL=https://your-api.azurewebsites.net
